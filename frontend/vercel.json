{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://book2audio-backend.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
